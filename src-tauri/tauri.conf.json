{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "StudioManager",
  "version": "1.2.3",
  "identifier": "ch.studiomanager.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "StudioManager",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: blob: data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https://github.com"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/lorisbriguet/StudioManager/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY4MEU3QkJGNjA2QTcwNkUKUldSdWNHcGd2M3NPYUNjOGlFRXk3SFJ0UmJERkJlaW1QbC9kTFlJYmFCQ0dHR2hNeWM4b0g1c0IK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  }
}
