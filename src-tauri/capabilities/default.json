{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    "fs:allow-copy-file",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:scope-appdata-recursive",
    {
      "identifier": "fs:scope",
      "allow": ["$HOME/**/*"]
    },
    "updater:default",
    "process:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "osascript",
          "cmd": "osascript",
          "args": ["-e", { "validator": "[\\s\\S]+" }]
        },
        {
          "name": "osascript-jxa",
          "cmd": "osascript",
          "args": ["-l", "JavaScript", "-e", { "validator": "[\\s\\S]+" }]
        },
        {
          "name": "python3",
          "cmd": "python3",
          "args": ["-c", { "validator": "[\\s\\S]+" }]
        }
      ]
    }
  ]
}
